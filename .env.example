# Copy to .env for local docker compose (never commit .env).
# On Render, set these as environment secrets.

# Ethereum Sepolia HTTPS (QuickNode preferred for sustained sync)
L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Must match sequencer slot override (Sepolia ~12s; calldata DA / beacon ignored)
L1_BLOCK_TIME=12

# Optional: pin JWT across restarts (64 hex chars). Empty → generated on disk volume.
# JWT_SECRET=

# Optional: 0 = wait forever while geth pid alive (Render archive recovery)
# GETH_READY_TIMEOUT_SECS=0
# geth --cache MB (default 256). Raise on ≥2GB hosts; Starter 512MB RAM cannot run this stack.
# GETH_CACHE_MB=256
